# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# The test env appends a "_test" suffix to the DATABASE_URL dbname (see
# config/packages/doctrine.yaml when@test), so the dev "store" database
# becomes "store_test" here automatically — a dedicated DB that a test run can
# migrate and truncate without touching development data. DAMA additionally
# wraps each test in a transaction and rolls it back, so the migrated schema is
# shared across tests without cross-test pollution.

# No real mail in tests — discard messages silently.
MAILER_DSN=null://null
